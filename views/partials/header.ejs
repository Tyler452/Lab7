<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Lab 7</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="icon" href="/favicon.svg" type="image/svg+xml">
    <link rel="stylesheet" href="/styles.css">
</head>
<body class="app-shell">
<nav class="navbar navbar-expand-lg border-bottom shadow-sm bg-white mb-4">
  <div class="container">
    <a class="navbar-brand fw-bold" href="/">Famous Quotes Admin</a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="mainNav">
      <% if (isAuthenticated) { %>
        <ul class="navbar-nav me-auto mb-2 mb-lg-0">
          <li class="nav-item"><a class="nav-link" href="/">Dashboard</a></li>
          <li class="nav-item"><a class="nav-link" href="/addAuthor">Add Author</a></li>
          <li class="nav-item"><a class="nav-link" href="/addQuote">Add Quote</a></li>
          <li class="nav-item"><a class="nav-link" href="/authors">Authors</a></li>
          <li class="nav-item"><a class="nav-link" href="/quotes">Quotes</a></li>
        </ul>
        <div class="d-flex align-items-center gap-2">
          <span class="small text-secondary">Signed in as <strong><%= currentUser %></strong></span>
          <form action="/logout" method="POST" class="m-0">
            <button class="btn btn-outline-danger btn-sm">Logout</button>
          </form>
        </div>
      <% } else { %>
        <ul class="navbar-nav ms-auto">
          <li class="nav-item"><a class="nav-link" href="/login">Login</a></li>
        </ul>
      <% } %>
    </div>
  </div>
</nav>

<main class="container pb-4">