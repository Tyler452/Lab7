<%- include('partials/header') %>
<div class="card">
    <div class="card-body">
        <h1 class="h3 mb-3">Update Quote</h1>

        <form action="/updateQuote" method="POST" class="row g-3">
            <input type="hidden" name="quoteId" value="<%= quoteInfo[0].quoteId %>">

            <div class="col-12">
                <label class="form-label">Quote</label>
                <textarea name="quote" class="form-control" rows="3" required><%= quoteInfo[0].quote %></textarea>
            </div>

            <div class="col-md-6">
                <label class="form-label">Category</label>
                <select name="category" class="form-select">
                    <option value="">Choose category</option>
                    <% for (let c of categories) { %>
                        <option value="<%= c.category %>" <%= quoteInfo[0].category === c.category ? 'selected' : '' %>><%= c.category %></option>
                    <% } %>
                </select>
            </div>

            <div class="col-md-6">
                <label class="form-label">Or New Category</label>
                <input type="text" name="newCategory" class="form-control">
            </div>

            <div class="col-12">
                <label class="form-label">Author</label>
                <select name="authorId" class="form-select" required>
                    <% for (let i of authors) { %>
                        <option value="<%= i.authorId %>" <%= String(quoteInfo[0].authorId) === String(i.authorId) ? 'selected' : '' %>>
                            <%= i.firstName %> <%= i.lastName %>
                        </option>
                    <% } %>
                </select>
            </div>

            <div class="col-12 d-flex gap-2">
                <button class="btn btn-primary">Save Changes</button>
                <a href="/quotes" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

<%- include('partials/footer') %>